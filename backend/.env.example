APP_NAME=IDE Builder MVP
ENV=dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ide_builder
JWT_SECRET=replace-with-strong-secret
JWT_ALGORITHM=HS256
